.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.TemporaryItems

# IDE and editor configurations
# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs (IntelliJ, CLion, etc.)
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Other editors
*.bak
*.tmp

# Build outputs
dist/
build/
out/

# Log files
*.log
logs/

# Environment files (may contain secrets)
.env
.env.*
!.env.example

# Keep docs directory for open source documentation
# (docs/ is intentionally NOT ignored)
