# Disco CLI 通用字符串

# 状态指示器
status-success = 成功
status-error = 错误
status-warning = 警告
status-info = 信息

# 在线/离线状态
status-online = 在线
status-offline = 离线
status-connected = 已连接
status-conflict = 身份冲突
status-mounted = 已挂载到 {$path}
status-index-available = 离线（索引可用）

# 大小单位
size-tb = {$value} TB
size-gb = {$value} GB
size-mb = {$value} MB
size-kb = {$value} KB
size-b = {$value} B

# 通用操作
action-cancelled = 已取消。
action-complete = 完成。
action-continue = 按回车继续...
action-continue-or-esc = 按 Enter 或 Esc 继续...
action-goodbye = 再见！

# 确认
confirm-proceed = 是否继续？[y/N]
confirm-remove-disk = 确定要删除硬盘 {$disk} 吗？[y/N]

# 导航
nav-back = 返回
nav-root = 根目录
nav-path = 路径: {$path}

# 计数器
count-files = {$count} 个文件
count-folders = {$count} 个文件夹
count-items = {$count} 项
count-disks = {$count} 个硬盘

# 标签
label-status = 状态
label-capacity = 容量
label-files = 文件数
label-suggestion = 建议
label-critical = 严重

# 通用消息
no-disks-registered = 没有注册的硬盘。使用 'disco disk add <挂载点>' 添加硬盘。
no-matching-disks = 没有找到匹配的硬盘。
no-files-found = 没有找到文件。
no-folders-found = 没有找到文件夹。
no-items-selected = 没有选择任何项目。
no-valid-paths = 没有有效的存储路径。

# 哈希校验状态
hash-enabled = 哈希校验已开启
hash-disabled = 哈希校验已关闭

# 语言切换
lang-switched = 语言已切换为 {$lang}
language-switched = 语言切换成功